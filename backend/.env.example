# Glimmer City Backend — Environment Variables
#
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# Server
PORT=4000
NODE_ENV=production

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:8483,http://localhost:3000

# DeepSeek (付费 LLM)
DEEPSEEK_API_KEY=YOUR_KEY
DEEPSEEK_MODEL=deepseek-chat

# Ollama (本地/自托管 LLM，可选)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e2b

# Player request signature (用于 X-Player-Signature)
PLAYER_SIGNATURE_SECRET=change-me-in-production
PLAYER_SIGNATURE_MAX_SKEW_MS=300000

# Logging
# LOG_LEVEL=debug

