# 基礎伺服器配置
PORT=4000
NODE_ENV=production

# CORS 許可域名 (多個域名用逗號分隔，* 代表允許所有)
CORS_ORIGIN=*

# DeepSeek API (核心 LLM)
DEEPSEEK_API_KEY=YOUR_KEY
DEEPSEEK_MODEL=deepseek-chat

# Player request signature (用於 X-Player-Signature)
# 前後端必須一致，否則會返回 401
PLAYER_SIGNATURE_SECRET=i-dont-have-enough-credit-to-make-this-game
PLAYER_SIGNATURE_MAX_SKEW_MS=300000
