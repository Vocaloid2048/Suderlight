{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "./dist",
  "nodeVersion": "22.11.0",
  "headers": [
    {
      "source": "/assets/*",
      "headers": [
        { "key": "Cache-Control", "value": "max-age=31536000" }
      ]
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "maxDuration": 60
    }
  }
}
